using Microsoft.Extensions.DependencyInjection;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using Todo.Domain.Repositories;
using Todo.Infrastructure.Repositories;

namespace Todo.Infrastructure
{
    public static class InfrastructureModules
    {
        public static IServiceCollection AddInfrastructureModels (this IServiceCollection services)
        {
            services.AddScoped<ITodoRepository, Todo.Infrastructure.Repositories.TodoRepository>();
            return services;
        }
    }
}
